{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI: uvicorn (backend)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "main:app",
        "--reload",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}/backend",
      "jinja": true,
      "justMyCode": false,
      "envFile": "${workspaceFolder}/backend/.env"
    },
    {
      "name": "Next.js: dev (frontend-next)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/frontend-next",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "KrishiAI: full stack (backend + frontend)",
      "configurations": [
        "FastAPI: uvicorn (backend)",
        "Next.js: dev (frontend-next)"
      ]
    }
  ]
}
