# Copy this file to `.env` and fill in real values.
# NEVER commit .env to git.

# ============================================================
# WEATHER PROVIDERS
# System auto-selects the primary provider by priority:
#   OpenWeatherMap (10) -> WeatherAPI (20) -> Tomorrow.io (30) -> AccuWeather (40)
# Only the keys you fill in are activated; missing ones are skipped.
# You need AT LEAST ONE for the weather endpoints to work.
# ============================================================

# OpenWeatherMap — primary. Free tier: 60 calls/min, 1M/month.
# Sign up: https://home.openweathermap.org/api_keys
# New keys take ~10 minutes to activate.
OPENWEATHERMAP_API_KEY=your_openweathermap_key_here

# WeatherAPI.com — fallback. Free tier: 1M calls/month.
# Sign up: https://www.weatherapi.com/signup.aspx
WEATHERAPI_API_KEY=

# Tomorrow.io — fallback. Free tier: 500 calls/day.
# Sign up: https://app.tomorrow.io/signup
TOMORROWIO_API_KEY=

# AccuWeather — fallback. Free tier: 50 calls/day (limited).
# Sign up: https://developer.accuweather.com
ACCUWEATHER_API_KEY=

# ============================================================
# CHATBOT / VOICE ASSISTANT
# Streaming multilingual assistant (Hindi / Kannada / English).
#   - OPENAI_API_KEY powers LLM (gpt-4o-mini), Whisper STT, and fallback TTS.
#   - SARVAM_API_KEY (optional) -> premium Indic TTS via Sarvam Bulbul.
#   - GOOGLE_APPLICATION_CREDENTIALS (optional, absolute path to a GCP
#     service-account JSON) -> Google Cloud Neural2 TTS.
# If no TTS provider is configured, the server returns a JSON hint and the
# browser speaks via the Web Speech API (SpeechSynthesis).
# OPENAI_CHAT_MODEL can be overridden (gpt-4o-mini | gpt-4o | …).
# CHAT_RATE_LIMIT_PER_MINUTE is a per-IP limit specifically for /api/chat/*
# (separate from the weather rate limit below).
# ============================================================
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
SARVAM_API_KEY=
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\gcp-service-account.json
CHAT_RATE_LIMIT_PER_MINUTE=30

# ============================================================
# CACHE
# If REDIS_URL is set, the app uses Redis (recommended for prod).
# Otherwise it falls back to an in-memory TTL dict (fine for dev).
# ============================================================
# REDIS_URL=redis://localhost:6379/0
CACHE_TTL_CURRENT=300       # 5 min — current weather
CACHE_TTL_FORECAST=900      # 15 min — forecast
CACHE_TTL_SEARCH=3600       # 1 hour — location search

# ============================================================
# RATE LIMITING (per client IP)
# ============================================================
RATE_LIMIT_PER_MINUTE=60

# ============================================================
# APP
# ============================================================
DEBUG=True
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
API_TIMEOUT=5.0

# ============================================================
# GEOLOCATION (free, no key, 45 req/min)
# ============================================================
GEOIP_PROVIDER_URL=http://ip-api.com/json

# ============================================================
# DATABASE (optional, defaults to sqlite:///./krishiai.db)
# ============================================================
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/krishiai
